{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a member or admin in the networking ecosystem.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "businessName": { "type": "string" },
        "category": { "type": "string" },
        "role": { "type": "string", "enum": ["MASTER_ADMIN", "CHAPTER_ADMIN", "MEMBER"] },
        "membershipStatus": { "type": "string", "enum": ["ACTIVE", "SUSPENDED", "PENDING"] },
        "subscriptionStart": { "type": "string", "format": "date-time" },
        "subscriptionEnd": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "website": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "state": { "type": "string" },
        "city": { "type": "string" },
        "area": { "type": "string" },
        "address": { "type": "string" },
        "adminId": { "type": "string", "description": "The ID of the admin who created this user." }
      },
      "required": ["uid", "name", "email", "role", "membershipStatus"]
    },
    "Position": {
      "title": "Position",
      "description": "Represents a leadership position held by a user in a chapter.",
      "type": "object",
      "properties": {
        "chapterAdminId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "position": { "type": "string", "enum": ["President", "Vice President", "Treasurer"] }
      },
      "required": ["chapterAdminId", "userId", "position"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification sent to a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["MASTER_ADMIN", "CHAPTER_ADMIN", "MEMBER"] },
        "type": { "type": "string", "enum": ["REFERRAL", "THANKYOU", "MEMBER_ADD", "SUBSCRIPTION", "UPGRADE"] },
        "message": { "type": "string" },
        "read": { "type": "boolean", "description": "Whether the notification has been read." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "type", "message", "createdAt"]
    },
    "Meeting": {
      "title": "Meeting",
      "description": "A weekly networking meeting.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "attendance": {
          "type": "object",
          "description": "Map of userId to attendance status"
        },
        "amountCollected": {
          "type": "object",
          "description": "Map of userId to amount collected"
        },
        "notes": { "type": "string" }
      },
      "required": ["date"]
    },
    "Referral": {
      "title": "Referral",
      "description": "A business referral passed between members.",
      "type": "object",
      "properties": {
        "fromUserId": { "type": "string" },
        "fromUserName": { "type": "string" },
        "fromUserRole": { "type": "string", "enum": ["MASTER_ADMIN", "CHAPTER_ADMIN", "MEMBER"] },
        "toUserId": { "type": "string" },
        "contactName": { "type": "string" },
        "contactPhone": { "type": "string" },
        "requirement": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "CONTACTED", "CONVERTED", "CLOSED", "COMPLETED", "NOT_CONVERTED"] },
        "notConvertedReason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUserId", "toUserId", "status"]
    },
    "ThankYouSlip": {
      "title": "ThankYouSlip",
      "description": "A record of business generated from a referral.",
      "type": "object",
      "properties": {
        "referralId": { "type": "string" },
        "fromUserId": { "type": "string" },
        "toUserId": { "type": "string" },
        "customerName": { "type": "string" },
        "businessValue": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["referralId", "fromUserId", "toUserId", "businessValue"]
    },
    "GuestInvitation": {
      "title": "GuestInvitation",
      "description": "An invitation sent to a guest.",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "guestName": { "type": "string" },
        "guestPhone": { "type": "string" },
        "guestBusiness": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["memberId", "guestName"]
    },
    "Category": {
      "title": "Category",
      "description": "Business categories available for members.",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Application": {
      "title": "Application",
      "description": "A registration request from a potential member.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "mobile": { "type": "string" },
        "companyName": { "type": "string" },
        "businessCategory": { "type": "string" },
        "address": { "type": "string" },
        "meetingSlot": { "type": "string" },
        "adminId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "mobile", "businessCategory", "status"]
    },
    "SMSMessage": {
      "title": "SMSMessage",
      "description": "A message to be sent via SMS extension.",
      "type": "object",
      "properties": {
        "to": { "type": "string", "description": "The recipient's phone number in E.164 format." },
        "body": { "type": "string", "description": "The content of the SMS message." },
        "status": { "type": "object", "description": "Status of the delivery, updated by the extension." }
      },
      "required": ["to", "body"]
    },
    "OneToOneMeeting": {
      "title": "OneToOneMeeting",
      "description": "A personal networking session between members.",
      "type": "object",
      "properties": {
        "creatorId": { "type": "string" },
        "participantIds": { "type": "array", "items": { "type": "string" } },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "venue": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["UPCOMING", "COMPLETED"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["creatorId", "participantIds", "date", "time", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/meetings/{meetingId}": { "schema": "Meeting", "description": "Weekly meeting records" },
    "/referrals/{referralId}": { "schema": "Referral", "description": "Referral tracking" },
    "/thank_you_slips/{slipId}": { "schema": "ThankYouSlip", "description": "Business conversion records" },
    "/guest_invitations/{invitationId}": { "schema": "GuestInvitation", "description": "Guest invites" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Global business categories" },
    "/applications/{applicationId}": { "schema": "Application", "description": "Registration requests" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" },
    "/messages/{messageId}": { "schema": "SMSMessage", "description": "Collection monitored by the Trigger SMS extension" },
    "/one_to_one_meetings/{meetingId}": { "schema": "OneToOneMeeting", "description": "Member-initiated networking sessions" },
    "/positions/{positionId}": { "schema": "Position", "description": "Chapter leadership positions" }
  }
}
