rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, chapterId, businessName, category, phone, website, bio, status, subscriptionExpiry, createdAt
    //
    // Collection: chapters
    // Fields: name, location, meetingDay, meetingTime, meetingVenue, adminIds, status, createdAt
    //
    // Collection: meetings
    // Fields: chapterId, date, attendance (map)
    //
    // Collection: referrals
    // Fields: fromUserId, toUserId, chapterId, contactName, contactPhone, requirement, notes, status, createdAt
    //
    // Collection: thank_you_slips
    // Fields: referralId, fromUserId, toUserId, chapterId, customerName, businessValue, notes, createdAt
    //
    // Collection: guest_invitations
    // Fields: memberId, chapterId, guestName, guestPhone, guestBusiness, createdAt
    //
    // Collection: categories
    // Fields: name
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "sskbusinessnetwork@gmail.com" && request.auth.token.email_verified == true));
    }

    function isChapterAdmin(chapterId) {
      return isAuthenticated() && 
        (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'chapter_admin' && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.chapterId == chapterId);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.email is string &&
             data.role in ['admin', 'chapter_admin', 'member', 'guest'];
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'guest';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    match /chapters/{chapterId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /meetings/{meetingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isChapterAdmin(request.resource.data.chapterId);
    }

    match /referrals/{referralId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isAuthenticated() && (request.resource.data.fromUserId == request.auth.uid || request.resource.data.toUserId == request.auth.uid);
    }

    match /thank_you_slips/{slipId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /guest_invitations/{invitationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.memberId == request.auth.uid;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
